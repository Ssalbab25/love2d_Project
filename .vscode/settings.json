{
    "editor.formatOnSave": true,
    "files.associations": {
        "*.lua": "lua"
    },
    "Lua.runtime.version": "LuaJIT",
    "Lua.runtime.pathStrict": true,
    "Lua.diagnostics.globals": [
        "love",
        "jit",
        "utf8"
    ],
    "Lua.workspace.checkThirdParty": false,
    "Lua.workspace.library": [
        "${3rd}/love2d/library"
    ],
    "code-runner.executorMap": {
        "lua": "chcp 65001 > nul && lua"
    },
    "code-runner.runInTerminal": false,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "args": ["-NoExit", "-Command", "[Console]::InputEncoding = [System.Text.Encoding]::UTF8; [Console]::OutputEncoding = [System.Text.Encoding]::UTF8; $OutputEncoding = [System.Text.Encoding]::UTF8"]
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": ["/K", "chcp 65001 > nul"],
            "icon": "terminal-cmd"
        }
    }
}