{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Love2D: Run project",
            "type": "shell",
            "command": "love",
            "args": [
                "${workspaceFolder}/src"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "cmd.exe",
                "args": [
                    "/c",
                    "chcp 65001 > nul && \"${workspaceFolder}/love-11.5-win64/lovec.exe\" \"${workspaceFolder}/src\""
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "Love2D: Run project (Global)",
            "type": "shell",
            "command": "love",
            "args": [
                "${workspaceFolder}/src"
            ],
            "windows": {
                "command": "cmd.exe",
                "args": [
                    "/c",
                    "chcp 65001 > nul && love \"${workspaceFolder}/src\""
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "Run run.bat",
            "type": "shell",
            "command": "${workspaceFolder}/run.bat",
            "problemMatcher": []
        },
        {
            "label": "Run run.sh",
            "type": "shell",
            "command": "${workspaceFolder}/run.sh",
            "osx": {
                "command": "${workspaceFolder}/run.sh"
            },
            "linux": {
                "command": "${workspaceFolder}/run.sh"
            },
            "windows": {
                "command": "${workspaceFolder}/run.bat"
            },
            "problemMatcher": []
        },
        {
            "label": "Lua: Run current file",
            "type": "shell",
            "command": "lua",
            "args": [
                "${file}"
            ],
            "windows": {
                "command": "cmd.exe",
                "args": [
                    "/c",
                    "chcp 65001 > nul && lua \"${file}\""
                ]
            },
            "problemMatcher": []
        }
    ]
}